<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="${basedir}/logs/internal/nlog-internal.log">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <target name="ErrorLog" xsi:type="File"
            filename="${basedir}/logs/error/log-${shortdate}.log"
            layout="${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
            archiveFileName="${basedir}/logs/error/backup/log.{#}.log"
            archiveNumbering="Date"
            archiveEvery="Day"
            archiveDateFormat="yyyyMMdd" />
    <target name="InfoLog" xsi:type="File"
            filename="${basedir}/logs/info/log-${shortdate}.log"
            layout="${longdate}|${uppercase:${level}}|${message}"
            archiveFileName="${basedir}/logs/info/backup/log.{#}.log"
            archiveNumbering="Date"
            archiveEvery="Day"
            archiveDateFormat="yyyyMMdd" />
    <target name="Console" xsi:type="ColoredConsole"
            layout="${longdate}|${uppercase:${level}}|${message}${onexception:inner= ${exception:format=tostring}}">
      <highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
      <highlight-row condition="level == LogLevel.Warn" foregroundColor="Yellow" />
      <highlight-row condition="level == LogLevel.Info" foregroundColor="Gray" />
    </target>
  </targets>

  <rules>
    <!-- Show startup URL and shutdown messages in console -->
    <logger name="Microsoft.Hosting.Lifetime" minlevel="Info" writeTo="Console" final="true" />
    <!-- Suppress other noisy framework logs -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />
    <!-- App logs: errors to file + console, info to file + console -->
    <logger name="*" minlevel="Error" writeTo="ErrorLog,Console" />
    <logger name="InfoLog" minlevel="Info" writeTo="InfoLog,Console" />
  </rules>

</nlog>
