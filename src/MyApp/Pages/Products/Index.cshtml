@page
@model MyApp.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Products</h4>
    @if (User.IsInRole(AppRoles.Admin))
    {
        <a asp-page="./Create" class="btn btn-success">+ Add Product</a>
    }
</div>

<table id="productsTable" class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Price</th>
            <th>Quantity</th>
            @if (User.IsInRole(AppRoles.Admin))
            {
                <th>Actions</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Products)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Description</td>
                <td>@p.Price.ToString("C")</td>
                <td>@p.Quantity</td>
                @if (User.IsInRole(AppRoles.Admin))
                {
                    <td>
                        <a asp-page="./Edit" asp-route-id="@p.Id" class="btn btn-sm btn-primary">Edit</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () { $('#productsTable').DataTable(); });
    </script>
}
