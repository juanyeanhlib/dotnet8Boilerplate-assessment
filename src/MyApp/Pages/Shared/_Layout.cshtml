<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <style>
        body { display: flex; min-height: 100vh; }
        #sidebar { width: 220px; min-height: 100vh; background: #343a40; flex-shrink: 0; }
        #sidebar a { color: #adb5bd; display: block; padding: 10px 16px; text-decoration: none; }
        #sidebar a:hover, #sidebar a.active { color: #fff; background: #495057; }
        #sidebar .sidebar-heading { color: #6c757d; padding: 10px 16px; font-size: 0.75rem; text-transform: uppercase; }
        #main { flex: 1; display: flex; flex-direction: column; }
        #topbar { background: #fff; border-bottom: 1px solid #dee2e6; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; }
        #content { padding: 24px; flex: 1; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav id="sidebar">
            <div class="py-3 px-3 text-white fw-bold fs-5">MyApp</div>
            <a asp-page="/Index">Home</a>

            <div class="sidebar-heading mt-2">Products</div>
            <a asp-page="/Products/Index">All Products</a>
            @if (User.IsInRole(AppRoles.Admin))
            {
                <a asp-page="/Products/Create">Add Product</a>
            }

            <div class="sidebar-heading mt-2">Requests</div>
            <a asp-page="/ProductRequests/Create">New Request</a>
            <a asp-page="/ProductRequests/Index">My Requests</a>
            @if (User.IsInRole(AppRoles.Manager) || User.IsInRole(AppRoles.Admin))
            {
                <a asp-page="/ProductRequests/Pending">Pending Review</a>
            }

            @if (User.IsInRole(AppRoles.Admin))
            {
                <div class="sidebar-heading mt-2">Admin</div>
                <a asp-page="/Admin/Users">Users</a>
            }

            <div class="mt-auto p-3" style="position:absolute;bottom:0;width:220px;">
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="btn btn-outline-light btn-sm w-100">Logout</button>
                </form>
            </div>
        </nav>
    }

    <div id="main">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div id="topbar">
                <span class="text-muted">@ViewData["Title"]</span>
                <span class="text-dark">@User.Identity.GetFullName()</span>
            </div>
        }
        <div id="content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
