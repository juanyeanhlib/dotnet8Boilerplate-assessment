@page
@model MyApp.Pages.ProductRequests.IndexModel
@{
    ViewData["Title"] = "My Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>My Requests</h4>
    <a asp-page="./Create" class="btn btn-success">+ New Request</a>
</div>

<table id="requestsTable" class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Product</th>
            <th>Type</th>
            <th>Quantity</th>
            <th>Status</th>
            <th>Review Remark</th>
            <th>Created</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model.Requests)
        {
            <tr>
                <td>@r.Id</td>
                <td>@r.Product.Name</td>
                <td>@r.RequestType</td>
                <td>@r.RequestedQuantity</td>
                <td>
                    <span class="badge bg-@(r.Status == RequestStatus.Approved ? "success" : r.Status == RequestStatus.Rejected ? "danger" : r.Status == RequestStatus.Submitted ? "warning" : "secondary")">
                        @r.Status
                    </span>
                </td>
                <td>@r.ReviewRemark</td>
                <td>@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (r.Status == RequestStatus.Draft)
                    {
                        <form method="post" asp-page-handler="Submit" style="display:inline;">
                            <input type="hidden" name="requestId" value="@r.Id" />
                            <button type="submit" class="btn btn-sm btn-primary">Submit</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () { $('#requestsTable').DataTable({ order: [[6, 'desc']] }); });
    </script>
}
