<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: #f0f2f5;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        .auth-panel {
            width: 400px;
            min-height: 100vh;
            background: #1a1d23;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 40px;
            flex-shrink: 0;
        }

        .auth-form-area {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 24px;
        }

        .auth-card {
            background: #fff;
            border-radius: 12px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        }

        @@media (max-width: 768px) {
            .auth-panel { display: none; }
        }
    </style>
</head>
<body>
    <div class="auth-panel">
        <div>
            <div class="d-flex align-items-center gap-2 mb-4">
                <div class="rounded-2 d-flex align-items-center justify-content-center"
                     style="width:36px;height:36px;background:#fff1;flex-shrink:0;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="white" viewBox="0 0 16 16">
                        <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zm.5 4.5v3.793l2.354 2.353-.708.708L7.5 8.707V4.5h1z"/>
                    </svg>
                </div>
                <span class="text-white fw-semibold fs-6">dotnet8 Boilerplate</span>
            </div>

            <h2 class="text-white fw-bold mb-2" style="font-size:1.6rem;line-height:1.3;">
                A solid foundation for your next app.
            </h2>
            <p class="mb-4" style="color:#8b9199;font-size:0.9rem;line-height:1.6;">
                Pre-wired with authentication, roles, audit logging, and a clean project structure — so you can focus on building features.
            </p>

            <div class="d-flex flex-column gap-2" style="font-size:0.82rem;">
                @foreach (var item in new[] {
                    ("ASP.NET Core Identity", "Authentication & user management"),
                    ("Entity Framework Core", "SQLite by default, SQL Server-ready"),
                    ("Role-based Authorization", "Admin, Manager, User roles"),
                    ("NLog", "Environment-aware structured logging"),
                    ("Audit Logging", "Track every data change"),
                })
                {
                    <div class="d-flex gap-2 align-items-start">
                        <svg class="mt-1 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="#4ade80" viewBox="0 0 16 16">
                            <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
                        </svg>
                        <div>
                            <span style="color:#e2e8f0;font-weight:500;">@item.Item1</span>
                            <span style="color:#6b7280;"> — @item.Item2</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="mt-auto pt-4" style="color:#4b5563;font-size:0.78rem;">
            .NET 8 · Razor Pages · Bootstrap 5
        </div>
    </div>

    <div class="auth-form-area">
        <div class="auth-card">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
